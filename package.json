{
  "name": "tomticketbot",
  "version": "1.0.0",
  "description": "Electron desktop app for TomTicket automation with Gemini-assisted workflows.",
  "main": "main.js",
  "keywords": [],
  "author": "Nicolas",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:dir": "electron-builder --dir",
    "test": "node --test"
  },
  "build": {
    "appId": "com.nicolas.smartservicedesk",
    "productName": "Smart Service Desk Automator",
    "files": [
      "**/*",
      "!tests{,/**}",
      "!test_*.js",
      "!api_response.json",
      "!debug_customers.json",
      "!model_test_log.txt",
      "!playwright-report{,/**}",
      "!blob-report{,/**}",
      "!test-results{,/**}"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Service Desk"
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.58.1",
    "dotenv": "^17.3.1"
  }
}
